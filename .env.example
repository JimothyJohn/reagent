# Azure Bot credentials
MSTEAMS_APP_ID=<your-azure-bot-app-id>
MSTEAMS_APP_PASSWORD=<your-azure-bot-app-password>
MSTEAMS_TENANT_ID=<your-azure-tenant-id>

# VM connection
VM_HOST=<your-vm>.eastus.cloudapp.azure.com
VM_IP=<your-vm-public-ip>
VM_USER=reagent

# Azure resource identifiers
RESOURCE_GROUP=reagent-rg
BOT_NAME=reagent-teams-bot
